# --- Client + server (REQUIRED) ---
# These NEXT_PUBLIC_* vars are inlined into the client bundle AT BUILD TIME, so
# they must be present wherever you build (local AND your deploy host, e.g. the
# Vercel project's Environment Variables). If they are missing at build time the
# Supabase client short-circuits to null and imports/trades/wallet linking all
# report "not configured".
NEXT_PUBLIC_SUPABASE_URL=https://mlysetytrewrpgmkcopj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-project-anon-key

# --- Server only (REQUIRED for admin features) ---
# Service role key — NEVER exposed to the client. Needed at RUNTIME on the server
# for the admin client (lib/supabase/admin.ts). Set it in your host's runtime env.
# Find it in Supabase Dashboard -> Project Settings -> API -> service_role.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# --- Optional: only needed for applying SQL locally with a Postgres client. ---
DATABASE_URL=postgresql://postgres:replace-with-database-password@db.mlysetytrewrpgmkcopj.supabase.co:5432/postgres
